---
import Layout from "../layouts/Layout.astro";
import { routeEngine } from "../routing";
import { templates } from "../templates";

const url = new URL(Astro.request.url);
let routeContext;

try {
	routeContext = await routeEngine.resolve(url);
} catch (error) {
	if (error.code === "ROUTE_NOT_FOUND") {
		return Astro.redirect("/404");
	}
	throw error;
}

const Template = templates[routeContext.template];

if (!Template) {
	return Astro.redirect("/404");
}
---

<Layout>
	<Fragment slot="head">
		<Template.Head routeContext={routeContext} />
	</Fragment>

	<Template.Body routeContext={routeContext} />
</Layout>
