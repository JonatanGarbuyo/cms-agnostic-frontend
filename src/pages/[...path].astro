---
import Layout from "../layouts/Layout.astro";
import { routeEngine } from "../routing";
import { TemplateNotFound } from "../routing/errors";
import { templates } from "../templates";

const url = new URL(Astro.request.url);
let routeContext;
let Template;

try {
	routeContext = await routeEngine.resolve(url);

	Template = templates[routeContext.template];

	if (!Template) {
		throw new TemplateNotFound({
			route: routeContext.route.name,
			template: routeContext.template,
		});
	}
} catch (error) {
	if (["ROUTE_NOT_FOUND", "CONTENT_NOT_FOUND", "TEMPLATE_NOT_FOUND"].includes(error.code)) {
		return Astro.redirect("/404");
	}

	if (error.code === "CONTENT_SOURCE_ERROR") {
		console.error("[RouteEngine]", error);
		return new Response("Internal Server Error", { status: 500 });
	}

	throw error;
}
---

<Layout>
	<Fragment slot="head">
		<Template.Head routeContext={routeContext} />
	</Fragment>

	<Template.Body routeContext={routeContext} />
</Layout>
