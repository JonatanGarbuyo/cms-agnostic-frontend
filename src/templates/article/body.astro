---
import articleViewModel from "./view-model";

const { routeContext } = Astro.props;
const vm = articleViewModel(routeContext);
const { articleUrl, description, headline } = vm;
---

<div class="article-layout">
	<div class="article-layout__top">
		<header class="masthead">
			<span> Masthead </span>
			<!-- <img src="logo" alt="logo" /> -->
			<nav>
				<ul class="masthead__nav-list">
					<li class="a span">home</li>
					<li class="a span">deportes</li>
					<li class="a span">nosotros</li>
				</ul>
			</nav>
		</header>
	</div>
	<div class="article-layout__fullwidth_top"></div>
	<div class="article-layout__body">
		<article>
			<h1>{headline}</h1>
		</article>
	</div>
	<div class="article-layout__rigth-rail"></div>
	<div class="article-layout__fullwidth_bottom"></div>
	<div class="article-layout__bottom"></div>
</div>
